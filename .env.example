# ============================================================
# GitHub Chat — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# OpenAI API key for embeddings + chat
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# URL of your Next.js frontend (used for CORS)
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Redis URL for rate limiting (optional — falls back to in-memory if unset)
# Upstash example: rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=

# Optional — override the chat model (default: gpt-4o-mini)
# CHAT_MODEL=gpt-4o

# Optional — chunking / retrieval tuning
# CHUNK_SIZE=120
# CHUNK_OVERLAP=20
# TOP_K=6
